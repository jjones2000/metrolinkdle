# Copy to .env for local development
# In Render, set these as environment variables in the dashboard

# Comma-separated list of allowed frontend origins
# Render: set to Netlify deployment URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://metrolinkdle.netlify.app

# Directory for SQLite database
# Railway: /data  (must match the volume mount path in railway.toml)
# Local:   ./data
DATA_DIR=./data
